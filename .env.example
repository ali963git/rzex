# ============================================
# RZEX Platform — Environment Variables
# ============================================

# --- General ---
NODE_ENV=development
LOG_LEVEL=debug

# --- API Gateway ---
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0

# --- User Service ---
USER_SERVICE_PORT=3001
JWT_SECRET=change-me-to-a-strong-secret
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=12

# --- Trading Engine ---
TRADING_ENGINE_PORT=3002

# --- Wallet Service ---
WALLET_SERVICE_PORT=3003

# --- Market Data Service ---
MARKET_DATA_PORT=3004

# --- Notification Service ---
NOTIFICATION_SERVICE_PORT=3005

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=rzex
POSTGRES_PASSWORD=rzex_dev_password
POSTGRES_DB=rzex

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MongoDB ---
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=rzex_market
MONGO_USER=rzex
MONGO_PASSWORD=rzex_dev_password

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3010
GRAFANA_ADMIN_PASSWORD=admin

# --- External APIs (Optional) ---
# COINGECKO_API_KEY=
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

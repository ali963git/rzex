# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=rzex_db
DB_USER=rzex_user
DB_PASSWORD=secure_password_change_me

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# MongoDB
MONGO_URL=mongodb://admin:admin_password@mongodb:27017/market_data

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=24h

# API Keys
API_KEY_SECRET=your_api_key_secret
ANTI_ABUSE_KEY=your_anti_abuse_key

# Services
USER_SERVICE_URL=http://user-service:3000
TRADING_ENGINE_URL=http://trading-engine:3000
MARKET_DATA_URL=http://market-data-service:3000
WALLET_SERVICE_URL=http://wallet-service:3000

# SMTP (للإشعارات)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@rzex.io

# AWS (اختياري)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Environment
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# Crypto
CRYPTO_SEED=your_secure_seed_phrase
HOT_WALLET_ADDRESS=0x...
COLD_WALLET_ADDRESS=0x...

# Trading
MIN_ORDER_SIZE=0.0001
MAX_ORDER_SIZE=1000000
TAKER_FEE=0.001
MAKER_FEE=0.0005

# 2FA
TOTP_WINDOW=1

# Frontend
REACT_APP_API_URL=http://localhost:3000
REACT_APP_WS_URL=ws://localhost:3000
